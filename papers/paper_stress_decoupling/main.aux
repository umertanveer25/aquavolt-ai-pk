\newlabel{subsec:vpd_threshold}{{4.3}{13}{VPD Threshold Analysis}{subsection.4.3}{}}
\newlabel{eq:logistic_real}{{11}{13}{VPD Threshold Analysis}{equation.11}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {4}{\ignorespaces (Left) Real logistic regression model: VPD vs.~P(Decoupled Stress) for corn (only crop with decoupled events; $\beta = 0.823$, AUC~$= 0.780$). Alfalfa and tomato are excluded as DSI~$= 0.000$ for both. (Right) Daily mean DSI and VPD across the 21-day pilot period; Pearson $r = -0.050$ ($p = 0.829$, n.s.), reflecting that aggregate multi-field DSI is dominated by alfalfa and tomato zeros.}}{14}{figure.caption.6}\protected@file@percent }
\newlabel{fig:vpd_logistic}{{4}{14}{(Left) Real logistic regression model: VPD vs.~P(Decoupled Stress) for corn (only crop with decoupled events; $\beta = 0.823$, AUC~$= 0.780$). Alfalfa and tomato are excluded as DSI~$= 0.000$ for both. (Right) Daily mean DSI and VPD across the 21-day pilot period; Pearson $r = -0.050$ ($p = 0.829$, n.s.), reflecting that aggregate multi-field DSI is dominated by alfalfa and tomato zeros}{figure.caption.6}{}}
\@writefile{toc}{\contentsline {subsection}{\numberline {4.4}Spatial Distribution of Decoupled Stress Events}{14}{subsection.4.4}\protected@file@percent }
\newlabel{subsec:spatial}{{4.4}{14}{Spatial Distribution of Decoupled Stress Events}{subsection.4.4}{}}
\@writefile{lot}{\contentsline {table}{\numberline {3}{\ignorespaces Real spatial autocorrelation diagnostics for sector-level DSI values. ICC computed as ratio of between-sector DSI variance to total DSI variance. Border vs. interior $t$-test applies to Field-A (Corn) only, as Alfalfa and Tomato have zero DSI throughout. n.s. = not significant ($p > 0.05$).}}{15}{table.caption.7}\protected@file@percent }
\newlabel{tab:spatial_stats}{{3}{15}{Real spatial autocorrelation diagnostics for sector-level DSI values. ICC computed as ratio of between-sector DSI variance to total DSI variance. Border vs. interior $t$-test applies to Field-A (Corn) only, as Alfalfa and Tomato have zero DSI throughout. n.s. = not significant ($p > 0.05$)}{table.caption.7}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {5}{\ignorespaces Spatial distribution of the Decoupled Stress Index (DSI) across the 8$\times $8 sector grids for each active crop field. Each cell displays the DSI value for that sector across the full monitoring period. The colour scale ranges from green (low DSI, stress well-coupled to soil moisture) to red (high DSI, predominantly atmospheric stress). Boundary sectors (rows/columns 0 and 7) exhibit systematically higher DSI values than interior sectors, consistent with hot-air advection from adjacent bare-soil surfaces.}}{15}{figure.caption.8}\protected@file@percent }
\newlabel{fig:spatial_dsi}{{5}{15}{Spatial distribution of the Decoupled Stress Index (DSI) across the 8$\times $8 sector grids for each active crop field. Each cell displays the DSI value for that sector across the full monitoring period. The colour scale ranges from green (low DSI, stress well-coupled to soil moisture) to red (high DSI, predominantly atmospheric stress). Boundary sectors (rows/columns 0 and 7) exhibit systematically higher DSI values than interior sectors, consistent with hot-air advection from adjacent bare-soil surfaces}{figure.caption.8}{}}
